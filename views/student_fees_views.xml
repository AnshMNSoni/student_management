<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_student_fees_list" model="ir.ui.view">
        <field name="name">student.fees.list</field>
        <field name="model">student.fees</field>
        <field name="arch" type="xml">
            <list string="Student Fees" create="0" edit="0">
                <field name="student_id"/>
                <field name="description"/>
                <field name="amount"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="state" widget="badge" decoration-success="state == 'paid'" decoration-info="state == 'draft'"/>
                <field name="sale_order_id"/>
                <field name="invoice_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_student_fees_form" model="ir.ui.view">
        <field name="name">student.fees.form</field>
        <field name="model">student.fees</field>
        <field name="arch" type="xml">
            <form string="Student Fee" create="0" edit="0">
                <header>
                    <button name="action_pay"
                            string="Pay Fees"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'paid'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,paid"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="description"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="sale_order_id" invisible="not sale_order_id"/>
                            <field name="invoice_id" invisible="not invoice_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_student_fees_search" model="ir.ui.view">
        <field name="name">student.fees.search</field>
        <field name="model">student.fees</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id"/>
                <field name="description"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="paid" string="Paid" domain="[('state', '=', 'paid')]"/>
                <group>
                    <filter string="Student" name="group_by_student" context="{'group_by':'student_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by':'state'}"/>
                    <filter string="Branch/Campus" name="group_by_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_student_fees" model="ir.actions.act_window">
        <field name="name">Student Fees</field>
        <field name="res_model">student.fees</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_student_fees_search"/>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="menu_student_fees"
        name="Student Fees"
        parent="menu_student_root"
        action="action_student_fees"
        sequence="30"
        groups="student_management.group_student,student_management.group_admin"
    />
</odoo>
