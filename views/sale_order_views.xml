<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_student_management" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.student.management</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add package dropdown below the delivery address field -->
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="package_id" string="Package" options="{'no_create': True}"/>
            </xpath>

            <!-- Show standard 'Add a product' link unless package is selected -->
            <xpath expr="//field[@name='order_line']/list/control/create[@name='add_product_control']" position="attributes">
                <attribute name="invisible">parent.package_id</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/control/create[@name='add_section_control']" position="attributes">
                <attribute name="invisible">parent.package_id</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/control/create[@name='add_note_control']" position="attributes">
                <attribute name="invisible">parent.package_id</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/list/control/button[@name='action_add_from_catalog']" position="attributes">
                <attribute name="invisible">parent.package_id</attribute>
            </xpath>

            <!-- Show standard 'Add a product' link on kanban (mobile) unless package is selected -->
            <xpath expr="//field[@name='order_line']/kanban/control/create[@name='add_product_control']" position="attributes">
                <attribute name="invisible">parent.package_id</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/kanban/control/create[@name='add_section_control']" position="attributes">
                <attribute name="invisible">parent.package_id</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/kanban/control/create[@name='add_note_control']" position="attributes">
                <attribute name="invisible">parent.package_id</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']/kanban/control/button[@name='action_add_from_catalog']" position="attributes">
                <attribute name="invisible">parent.package_id</attribute>
            </xpath>
        </field>
    </record>
</odoo>
