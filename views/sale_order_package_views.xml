<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_package_list" model="ir.ui.view">
        <field name="name">sale.order.package.list</field>
        <field name="model">sale.order.package</field>
        <field name="arch" type="xml">
            <list string="Sale Packages">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_sale_order_package_form" model="ir.ui.view">
        <field name="name">sale.order.package.form</field>
        <field name="model">sale.order.package</field>
        <field name="arch" type="xml">
            <form string="Sale Package">
                <sheet>
                    <field name="selected_product_ids" invisible="1"/>
                    <group>
                        <field name="name" placeholder="e.g. Standard I Package"/>
                    </group>
                    <notebook>
                        <page string="Products" name="products">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id" domain="[('id', 'not in', parent.selected_product_ids)]" options="{'no_create': True}"/>
                                    <field name="quantity"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sale_order_package" model="ir.actions.act_window">
        <field name="name">Sale Packages</field>
        <field name="res_model">sale.order.package</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_sale_order_package"
              name="Sale Packages"
              action="action_sale_order_package"
              parent="sale.prod_config_main"
              sequence="40"/>
</odoo>
