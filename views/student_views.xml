<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_student_list" model="ir.ui.view">
        <field name="name">student.management.list</field>
        <field name="model">student.management</field>
        <field name="arch" type="xml">
            <list string="Students" default_order="name asc">
                <button name="action_open_status_wizard_inactive"
                        string="Inactive"
                        type="object"
                        class="btn-secondary"
                        invisible="status != 'draft'"/>
                <button name="action_open_status_wizard_active"
                        string="Active"
                        type="object"
                        class="btn-primary"
                        invisible="status != 'inactive'"/>
                <field name="name" />
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="roll_number" />
                <field name="age" />
                <field name="email" widget="email" />
                <field name="admission_date" />
                <field name="fee_payment_deadline" />
                <field name="status" widget="badge" />
                <field name="fee_status" widget="badge" decoration-success="fee_status == 'paid'" decoration-warning="fee_status == 'unpaid'" decoration-info="fee_status == 'no_fees'"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_student_form" model="ir.ui.view">
        <field name="name">student.management.form</field>
        <field name="model">student.management</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <button name="action_open_status_wizard"
                        string="Change Status"
                        type="object"
                        class="btn-primary"
                        groups="student_management.group_teacher" />
                    <button name="action_open_fees_wizard"
                        string="Fees"
                        type="object"
                        class="btn-primary"
                        groups="student_management.group_admin" />
                    <field name="status" widget="statusbar" statusbar_visible="draft,inactive,active"/>
                </header>
                
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_quotations"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o"
                                groups="student_management.group_admin">
                            <field name="quotation_count" widget="statinfo" string="Quotations"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="roll_number" />
                            <field name="age" />
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>

                        <group>
                            <field name="email" widget="email" />
                            <field name="standard_id" required="1" string="Standard/Class" domain="[('company_id', '=', company_id)]"/>
                            <field name="standard" invisible="1"/>
                            <field name="subject_ids" widget="many2many_tags" domain="[('standard_name', '=', standard), '|', ('company_id', '=', False), ('company_id', '=', company_id)]" options="{'no_create': True}"/>
                            <field name="admission_date" />
                            <field name="fee_payment_deadline" />
                            <field name="fee_status" widget="badge" decoration-success="fee_status == 'paid'" decoration-warning="fee_status == 'unpaid'" decoration-info="fee_status == 'no_fees'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Results">
                            <field name="result_ids">
                                <list>
                                    <!-- <field name="student_id" invisible="1"/> -->
                                    <field name="sequence" readonly="1"/>
                                    <field name="result_date"/>
                                    <field name="overall_percentage" string="Overall Result (%)"/>
                                    <field name="overall_grade"/>
                                </list>
                                <form>
                                    <sheet>
                                        <field name="student_id" invisible="1"/>
                                        <group>
                                            <group>
                                                <field name="result_date"/>
                                            </group>
                                            <group>
                                                <field name="overall_percentage" string="Overall Result (%)" readonly="1"/>
                                                <field name="overall_grade" readonly="1"/>
                                            </group>
                                        </group>
                                        <notebook>
                                            <page string="Subject Results">
                                                <field name="result_line_ids">
                                                    <list editable="bottom">
                                                        <!-- <field name="allowed_subject_ids" invisible="1"/> -->
                                                        <field name="subject_id" domain="[('id', 'in', allowed_subject_ids)]" options="{'no_create': True}"/>
                                                        <field name="marks"/>
                                                        <field name="grade" readonly="1"/>
                                                    </list>
                                                    <form>
                                                        <group>
                                                            <!-- <field name="allowed_subject_ids" invisible="1"/> -->
                                                            <field name="subject_id" domain="[('id', 'in', allowed_subject_ids)]" options="{'no_create': True}"/>
                                                            <field name="marks"/>
                                                            <field name="grade" readonly="1"/>
                                                        </group>
                                                    </form>
                                                </field>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Fees">
                            <field name="fee_ids">
                                <list>
                                    <field name="description"/>
                                    <field name="amount"/>
                                    <field name="state" widget="badge" decoration-success="state == 'paid'" decoration-info="state == 'draft'"/>
                                    <field name="sale_order_id"/>
                                    <field name="invoice_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_student_search" model="ir.ui.view">
        <field name="name">student.management.search</field>
        <field name="model">student.management</field>
        <field name="arch" type="xml">
            <search string="Search Students">

                <!-- Search fields -->
                <field name="name" />
                <field name="roll_number" />
                <field name="email" />
                <field name="company_id" groups="base.group_multi_company"/>

                <!-- Filters -->
                <filter
                    name="filter_active"
                    string="Active"
                    domain="[('status', '=', 'active')]"
                />

                <filter
                    name="filter_inactive"
                    string="Inactive"
                    domain="[('status', '=', 'inactive')]"
                />

                <filter
                    name="filter_draft"
                    string="Draft"
                    domain="[('status', '=', 'draft')]"
                />

                <group>
                    <filter string="Branch/Campus" name="group_by_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>

            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_student_management" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">student.management</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_student_search" />
    </record>

    <!-- Root Menu -->
    <menuitem
        id="menu_student_root"
        name="Student Management"
        sequence="10"
    />

    <!-- Child Menu -->
    <menuitem
        id="menu_student"
        name="Students"
        parent="menu_student_root"
        action="action_student_management"
        sequence="10"
    />

</odoo>