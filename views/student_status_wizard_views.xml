<odoo>
    <!-- Wizard Form View -->
    <record id="view_student_status_wizard_form" model="ir.ui.view">
        <field name="name">student.status.wizard.form</field>
        <field name="model">student.status.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Student Status">
                <group>
                    <field name="student_id" readonly="1" />
                    <field name="new_status" />
                    <field name="reason" />
                </group>

                <footer>
                    <button name="action_confirm"
                        string="Confirm"
                        type="object"
                        class="btn-primary" />

                    <button string="Cancel"
                        special="cancel"
                        class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_student_status_wizard" model="ir.actions.act_window">
        <field name="name">Change Status</field>
        <field name="res_model">student.status.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_student_status_wizard_form" />
        <field name="target">new</field>
    </record>
</odoo>