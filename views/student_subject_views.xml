<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_student_subject_list" model="ir.ui.view">
        <field name="name">student.subject.list</field>
        <field name="model">student.subject</field>
        <field name="arch" type="xml">
            <list string="Subjects" create="0" edit="0">
                <field name="name"/>
                <field name="standard_name"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_student_subject_form" model="ir.ui.view">
        <field name="name">student.subject.form</field>
        <field name="model">student.subject</field>
        <field name="arch" type="xml">
            <form string="Subject" create="0" edit="0">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="standard_name"/>
                        <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_student_subject_search" model="ir.ui.view">
        <field name="name">student.subject.search</field>
        <field name="model">student.subject</field>
        <field name="arch" type="xml">
            <search string="Search Subjects">
                <field name="name"/>
                <field name="standard_name"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <group>
                    <filter string="Standard" name="group_by_standard" context="{'group_by':'standard_name'}"/>
                    <filter string="Branch/Campus" name="group_by_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_student_subject" model="ir.actions.act_window">
        <field name="name">Subjects</field>
        <field name="res_model">student.subject</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_student_subject_search"/>
        <field name="context">{'search_default_group_by_standard': 1}</field>
    </record>

    <!-- Menu Item -->
    <menuitem
        id="menu_student_subject"
        name="Subjects"
        parent="menu_student_root"
        action="action_student_subject"
        sequence="5"
    />
</odoo>
