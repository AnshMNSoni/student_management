<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Breadcrumbs -->
    <template id="portal_breadcrumbs_student" name="Portal layout : student breadcrumbs" inherit_id="portal.portal_breadcrumbs" priority="20">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'student_profile'" class="breadcrumb-item active">
                My Profile
            </li>
            <li t-if="page_name == 'student_results'" class="breadcrumb-item active">
                My Results
            </li>
            <li t-if="page_name == 'student_fees'" class="breadcrumb-item active">
                My Fees
            </li>
        </xpath>
    </template>

    <!-- Portal My Home Inherit -->
    <template id="portal_my_home_student" name="Student Portal My Home" inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-if="is_student" t-call="portal.portal_docs_entry">
                <t t-set="title">My Profile</t>
                <t t-set="url" t-value="'/my/student/profile'"/>
                <t t-set="text">View your student profile information</t>
                <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                <t t-set="placeholder_count" t-value="'student_count'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
            <t t-if="is_student" t-call="portal.portal_docs_entry">
                <t t-set="title">My Results</t>
                <t t-set="url" t-value="'/my/student/results'"/>
                <t t-set="text">Check your grades and exam marks</t>
                <t t-set="icon" t-value="'/portal/static/src/img/portal-addresses.svg'"/>
                <t t-set="placeholder_count" t-value="'result_count'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
            <t t-if="is_student" t-call="portal.portal_docs_entry">
                <t t-set="title">My Fees</t>
                <t t-set="url" t-value="'/my/student/fees'"/>
                <t t-set="text">View your fee status and history</t>
                <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                <t t-set="placeholder_count" t-value="'fees_count'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
            <t t-if="not is_student and not request.env.user.has_group('student_management.group_teacher')">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="title">Student Registration</t>
                    <t t-set="url" t-value="'/student/register'"/>
                    <t t-set="text">Register your student profile details</t>
                    <t t-set="icon" t-value="'/portal/static/src/img/portal-connection.svg'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </t>
        </xpath>
    </template>

    <!-- Profile View -->
    <template id="portal_student_profile" name="Student Profile">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            
            <div class="container my-4">
                <div class="card border-0 shadow-lg" style="border-radius: 16px; overflow: hidden; background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);">
                    <!-- Header with Gradient and Avatar -->
                    <div class="p-5 text-white position-relative" style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <t t-if="student.image_1920">
                                    <img t-att-src="image_data_uri(student.image_1920)" class="rounded-circle border border-4 border-white shadow object-fit-cover" style="width: 120px; height: 120px;" alt="Avatar"/>
                                </t>
                                <t t-else="">
                                    <div class="rounded-circle border border-4 border-white shadow d-flex align-items-center justify-content-center bg-light text-primary" style="width: 120px; height: 120px; font-size: 48px; font-weight: bold;">
                                        <t t-esc="student.name[0] if student.name else 'S'"/>
                                    </div>
                                </t>
                            </div>
                            <div class="col mt-3 mt-md-0">
                                <h1 class="fw-bold mb-1" t-esc="student.name"/>
                                <p class="mb-2 opacity-75 fs-5">
                                    <i class="fa fa-id-card-o me-2"/>Roll Number: <strong t-esc="student.roll_number"/>
                                </p>
                                <span class="badge rounded-pill px-3 py-2 fs-6 shadow-sm" t-attf-class="{{'bg-success' if student.status == 'active' else 'bg-warning text-dark' if student.status == 'draft' else 'bg-danger'}}">
                                    <t t-esc="student.status.capitalize()"/>
                                </span>
                                <div class="mt-3 d-flex gap-2">
                                    <a href="/my/student/results" class="btn btn-light text-primary fw-bold shadow-sm">
                                        <i class="fa fa-bar-chart me-2"/>My Results
                                    </a>
                                    <a href="/my/student/fees" class="btn btn-light text-success fw-bold shadow-sm">
                                        <i class="fa fa-money me-2"/>My Fees
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Content Body -->
                    <div class="card-body p-5">
                        <h3 class="fw-bold text-dark mb-4 border-bottom pb-2">Academic &amp; Personal Information</h3>
                        <div class="row g-4">
                            <!-- Class Card -->
                            <div class="col-md-6 col-lg-4">
                                <div class="p-4 rounded-3 border bg-white shadow-sm h-100 transition-all hover-elevate">
                                    <div class="text-primary mb-3" style="font-size: 24px;">
                                        <i class="fa fa-graduation-cap"/>
                                    </div>
                                    <h6 class="text-muted fw-bold text-uppercase mb-1">Standard/Class</h6>
                                    <p class="fs-5 fw-bold text-dark mb-0" t-esc="student.standard_id.name or 'Not Assigned'"/>
                                </div>
                            </div>
                            
                            <!-- Age Card -->
                            <div class="col-md-6 col-lg-4">
                                <div class="p-4 rounded-3 border bg-white shadow-sm h-100 transition-all hover-elevate">
                                    <div class="text-info mb-3" style="font-size: 24px;">
                                        <i class="fa fa-birthday-cake"/>
                                    </div>
                                    <h6 class="text-muted fw-bold text-uppercase mb-1">Age</h6>
                                    <p class="fs-5 fw-bold text-dark mb-0" t-esc="student.age or 'N/A'"/>
                                </div>
                            </div>

                            <!-- Admission Date Card -->
                            <div class="col-md-6 col-lg-4">
                                <div class="p-4 rounded-3 border bg-white shadow-sm h-100 transition-all hover-elevate">
                                    <div class="text-success mb-3" style="font-size: 24px;">
                                        <i class="fa fa-calendar"/>
                                    </div>
                                    <h6 class="text-muted fw-bold text-uppercase mb-1">Admission Date</h6>
                                    <p class="fs-5 fw-bold text-dark mb-0">
                                        <span t-field="student.admission_date" t-options="{'widget': 'date'}"/>
                                        <t t-if="not student.admission_date">N/A</t>
                                    </p>
                                </div>
                            </div>

                            <!-- Email Card -->
                            <div class="col-md-6 col-lg-6">
                                <div class="p-4 rounded-3 border bg-white shadow-sm h-100 transition-all hover-elevate">
                                    <div class="text-warning mb-3" style="font-size: 24px;">
                                        <i class="fa fa-envelope"/>
                                    </div>
                                    <h6 class="text-muted fw-bold text-uppercase mb-1">Email Address</h6>
                                    <p class="fs-5 fw-bold text-dark mb-0" t-esc="student.email or 'N/A'"/>
                                </div>
                            </div>

                            <!-- Phone Card -->
                            <div class="col-md-6 col-lg-6">
                                <div class="p-4 rounded-3 border bg-white shadow-sm h-100 transition-all hover-elevate">
                                    <div class="text-danger mb-3" style="font-size: 24px;">
                                        <i class="fa fa-phone"/>
                                    </div>
                                    <h6 class="text-muted fw-bold text-uppercase mb-1">Phone Number</h6>
                                    <p class="fs-5 fw-bold text-dark mb-0" t-esc="student.phone or 'N/A'"/>
                                </div>
                            </div>

                            <!-- Subjects Card -->
                            <div class="col-12">
                                <div class="p-4 rounded-3 border bg-white shadow-sm h-100 transition-all hover-elevate">
                                    <div class="text-primary mb-3" style="font-size: 24px;">
                                        <i class="fa fa-book"/>
                                    </div>
                                    <h6 class="text-muted fw-bold text-uppercase mb-2">Enrolled Subjects</h6>
                                    <div class="d-flex flex-wrap gap-2">
                                        <t t-if="student.subject_ids">
                                            <t t-foreach="student.subject_ids" t-as="subj">
                                                <span class="badge bg-primary text-white fs-6 px-3 py-2 rounded-pill shadow-sm" t-esc="subj.name"/>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <span class="text-muted fs-5">No subjects assigned for this standard.</span>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Results View -->
    <template id="portal_student_results" name="Student Results">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <div class="container my-4">
                <div class="card border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
                    <div class="p-4 text-white d-flex align-items-center justify-content-between" style="background: linear-gradient(135deg, #2b5876 0%, #4e4376 100%);">
                        <h2 class="mb-0 fw-bold"><i class="fa fa-bar-chart me-2"/>My Academic Results</h2>
                        <span class="badge bg-light text-dark fs-6 rounded-pill px-3" t-esc="'Total Subjects: %s' % len(results)"/>
                    </div>
                    
                    <div class="card-body p-4 bg-light">
                        <t t-if="not results">
                            <div class="alert alert-info text-center py-5 rounded-3 mb-0">
                                <i class="fa fa-info-circle fa-3x mb-3 text-info"/>
                                <h4>No Results Released</h4>
                                <p class="text-muted mb-0">Your exam results are not published yet.</p>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="table-responsive border rounded-3 bg-white shadow-sm">
                                <table class="table table-hover table-striped align-middle mb-0">
                                    <thead class="table-dark">
                                        <tr>
                                            <th class="ps-4">Sequence</th>
                                            <th>Class</th>
                                            <th>Overall Result (%)</th>
                                            <th>Overall Grade</th>
                                            <th>Result Date</th>
                                            <th class="pe-4">Subject Results</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="results" t-as="result">
                                            <tr>
                                                <td class="ps-4 fw-bold text-muted" t-esc="result.sequence"/>
                                                <td t-esc="result.standard_id.name or 'N/A'"/>
                                                <td>
                                                    <span class="fs-6 fw-bold" t-esc="result.overall_percentage"/>
                                                </td>
                                                <td>
                                                    <span class="badge px-3 py-2 rounded-pill shadow-sm" t-attf-class="{{'bg-success' if result.overall_grade == 'A' else 'bg-primary' if result.overall_grade == 'B' else 'bg-info text-dark' if result.overall_grade == 'C' else 'bg-warning text-dark' if result.overall_grade == 'D' else 'bg-danger'}}">
                                                        <t t-esc="result.overall_grade"/>
                                                    </span>
                                                </td>
                                                <td>
                                                    <span t-field="result.result_date" t-options="{'widget': 'date'}"/>
                                                    <t t-if="not result.result_date">-</t>
                                                </td>
                                                <td class="pe-4">
                                                    <div class="d-flex flex-column gap-1">
                                                        <t t-foreach="result.result_line_ids" t-as="line">
                                                            <div class="small text-muted">
                                                                <strong class="text-dark" t-esc="line.subject_id.name"/>: <t t-esc="line.marks"/> (<t t-esc="line.grade"/>)
                                                            </div>
                                                        </t>
                                                    </div>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                            <div t-if="pager" class="d-flex justify-content-center mt-3">
                                <t t-call="portal.pager"/>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Fees View -->
    <template id="portal_student_fees" name="Student Fees">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <div class="container my-4">
                <div class="card border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
                    <div class="p-4 text-white d-flex align-items-center justify-content-between" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                        <h2 class="mb-0 fw-bold"><i class="fa fa-money me-2"/>My Fee Records</h2>
                        <span class="badge bg-light text-dark fs-6 rounded-pill px-3" t-esc="'Payments: %s' % len(fees)"/>
                    </div>
                    
                    <div class="card-body p-4 bg-light">
                        <t t-if="not fees">
                            <div class="alert alert-info text-center py-5 rounded-3 mb-0">
                                <i class="fa fa-info-circle fa-3x mb-3 text-info"/>
                                <h4>No Fee Invoices Found</h4>
                                <p class="text-muted mb-0">There are no fee bills associated with your account.</p>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="table-responsive border rounded-3 bg-white shadow-sm">
                                <table class="table table-hover table-striped align-middle mb-0">
                                    <thead class="table-dark">
                                        <tr>
                                            <th class="ps-4">Fee ID</th>
                                            <th>Description</th>
                                            <th>Amount</th>
                                            <th>Status</th>
                                            <th class="pe-4">Associated Order</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="fees" t-as="fee">
                                            <tr>
                                                <td class="ps-4 fw-bold text-muted" t-esc="'#%s' % fee.id"/>
                                                <td class="fw-bold text-dark" t-esc="fee.description"/>
                                                <td class="fw-bold">
                                                    <span t-field="fee.amount" t-options='{"widget": "monetary", "display_currency": request.env.company.currency_id}'/>
                                                </td>
                                                <td>
                                                    <span class="badge px-3 py-2 rounded-pill shadow-sm" t-attf-class="{{'bg-success' if fee.state == 'paid' else 'bg-warning text-dark'}}">
                                                        <t t-esc="fee.state.capitalize()"/>
                                                    </span>
                                                </td>
                                                <td class="pe-4">
                                                    <t t-if="fee.sale_order_id">
                                                        <a t-attf-href="/my/orders/#{fee.sale_order_id.id}" class="btn btn-outline-primary btn-sm rounded-pill shadow-sm">
                                                            <i class="fa fa-file-text-o me-1"/>View Order: <t t-esc="fee.sale_order_id.name"/>
                                                        </a>
                                                    </t>
                                                    <t t-elif="fee.state == 'draft'">
                                                        <a t-attf-href="/my/student/fees/pay/#{fee.id}" class="btn btn-success btn-sm rounded-pill shadow-sm">
                                                            <i class="fa fa-credit-card me-1"/>Pay Now
                                                        </a>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="text-muted">-</span>
                                                    </t>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                            <div t-if="pager" class="d-flex justify-content-center mt-3">
                                <t t-call="portal.pager"/>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
