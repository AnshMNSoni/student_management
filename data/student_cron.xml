<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Server Action -->
        <record id="action_student_check_deadline_miss" model="ir.actions.server">
            <field name="name">Check Fee Payment Deadline Miss</field>
            <field name="model_id" ref="model_student_management"/>
            <field name="state">code</field>
            <field name="code">
                model._cron_check_payment_deadline()
            </field>
        </record>

        <!-- Scheduled Action (Cron) -->
        <record id="ir_cron_student_check_deadline_miss" model="ir.cron">
            <field name="name">Student: Check Fee Payment Deadline Miss</field>
            <field name="model_id" ref="model_student_management"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_payment_deadline()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
