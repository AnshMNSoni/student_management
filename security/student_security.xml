<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Category -->
    <record id="module_category_student_management" model="ir.module.category">
        <field name="name">Student Management</field>
        <field name="description">Category for Student Management Roles</field>
        <field name="sequence">20</field>
    </record>

    <!-- Groups Privilege -->
    <record model="res.groups.privilege" id="res_groups_privilege_student_management">
        <field name="name">Student Management</field>
        <field name="sequence">20</field>
        <field name="category_id" ref="module_category_student_management"/>
    </record>

    <!-- Groups -->
    <record id="group_student" model="res.groups">
        <field name="name">Student</field>
        <field name="privilege_id" ref="res_groups_privilege_student_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
    </record>

    <record id="group_teacher" model="res.groups">
        <field name="name">Teacher</field>
        <field name="privilege_id" ref="res_groups_privilege_student_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_partner_manager')), (4, ref('base.group_user'))]"/>
    </record>

    <record id="group_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="privilege_id" ref="res_groups_privilege_student_management"/>
        <field name="implied_ids" eval="[(4, ref('group_teacher'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Record Rules -->
    
    <!-- Student Management (Personal Rules) -->
    <record id="rule_student_personal_record" model="ir.rule">
        <field name="name">Personal Student Record</field>
        <field name="model_id" ref="model_student_management"/>
        <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_student'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_teacher_all_records" model="ir.rule">
        <field name="name">Teacher/Admin All Student Records</field>
        <field name="model_id" ref="model_student_management"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_teacher'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Student Results (Personal Rules) -->
    <record id="rule_student_personal_results" model="ir.rule">
        <field name="name">Personal Results</field>
        <field name="model_id" ref="model_student_result"/>
        <field name="domain_force">[('student_id.partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_student'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_teacher_all_results" model="ir.rule">
        <field name="name">Teacher/Admin All Results</field>
        <field name="model_id" ref="model_student_result"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_teacher'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Student Fees (Personal Rules) -->
    <record id="rule_student_personal_fees" model="ir.rule">
        <field name="name">Personal Fees</field>
        <field name="model_id" ref="model_student_fees"/>
        <field name="domain_force">[('student_id.partner_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_student'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_teacher_all_fees" model="ir.rule">
        <field name="name">Teacher/Admin All Fees</field>
        <field name="model_id" ref="model_student_fees"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_teacher'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Multi-Company Rules -->
    <record id="rule_student_management_multi_company" model="ir.rule">
        <field name="name">Student Profile Multi-Company</field>
        <field name="model_id" ref="model_student_management"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_student_standard_multi_company" model="ir.rule">
        <field name="name">Student Standard Multi-Company</field>
        <field name="model_id" ref="model_student_standard"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_student_subject_multi_company" model="ir.rule">
        <field name="name">Student Subject Multi-Company</field>
        <field name="model_id" ref="model_student_subject"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_student_result_multi_company" model="ir.rule">
        <field name="name">Student Result Multi-Company</field>
        <field name="model_id" ref="model_student_result"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_student_fees_multi_company" model="ir.rule">
        <field name="name">Student Fees Multi-Company</field>
        <field name="model_id" ref="model_student_fees"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
